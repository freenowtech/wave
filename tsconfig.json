{
    "compilerOptions": {
        "forceConsistentCasingInFileNames": true,
        "removeComments": true,
        "esModuleInterop": true,
        "moduleResolution": "node",
        "ignoreDeprecations": "6.0",
        "jsx": "react",
        "lib": ["dom", "es2023"],
        "declaration": true,
        "declarationDir": "lib/types/",
        "rootDir": "src/",
        "skipLibCheck": true,
        "skipDefaultLibCheck": true
    },
    "include": ["src/**/*"],
    "exclude": ["src/**/docs", "**/node_modules", "src/codemods"]
}
