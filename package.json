{
    "name": "@freenow/wave",
    "version": "2.49.1",
    "description": "React components of the Wave design system for your Front-End project",
    "main": "lib/cjs/index.js",
    "typings": "lib/types/index.d.ts",
    "module": "lib/esm/index.js",
    "exports": {
        ".": {
            "import": "./lib/esm/index.js",
            "require": "./lib/cjs/index.js",
            "default": "./lib/esm/index.js",
            "types": "./lib/types/index.d.ts"
        },
        "./experimental": {
            "import": "./lib/esm/experimental/index.js",
            "require": "./lib/cjs/experimental/index.js",
            "default": "./lib/esm/experimental/index.js",
            "types": "./lib/types/experimental/index.d.ts"
        }
    },
    "typesVersions": {
        "*": {
            "experimental": [
                "lib/types/experimental/index.d.ts"
            ]
        }
    },
    "bin": {
        "run_v2_migration": "./scripts/run_v2_migration.sh"
    },
    "sideEffects": false,
    "scripts": {
        "clean": "rm -rf lib",
        "build": "npm run clean && npm run build:cjs && npm run build:esm",
        "build:cjs": "tsc --target es2015 --module commonjs --outDir lib/cjs",
        "build:esm": "tsc --target es6 --module esnext --outDir lib/esm",
        "build:documentation": "storybook build",
        "generate": "npm run generate:icons",
        "generate:icons": "node ./scripts/generate-icons assets/icons -r -o src/icons --exclude-color-prop **/brands/** **/flags/** --exclude-suffix **/flags/**",
        "prettier": "pretty-quick --staged",
        "prepare": "husky",
        "test": "jest",
        "test:fixture": "./scripts/run_fixtures.sh",
        "test:watch": "jest --watch",
        "test:codemods": "jest codemods",
        "lint": "npm run lint:eslint",
        "lint:eslint": "eslint src/",
        "husky:commitMsg": "commitlint -E HUSKY_GIT_PARAMS",
        "husky:precommit": "npm run lint:eslint -- --fix && npm run prettier",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build"
    },
    "publishConfig": {
        "access": "public"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/freenowtech/wave.git"
    },
    "files": [
        "lib/",
        "codemods/"
    ],
    "license": "Apache-2.0",
    "overrides": {
        "react-refresh": "0.14.2",
        "react-is": "19.2.4",
        "wave-react-windowed-select": {
            "react": "19.2.4",
            "react-dom": "19.2.4",
            "@types/react": "^19.0.0"
        }
    },
    "peerDependencies": {
        "react": "^18.2.0 || ^19.0.0",
        "react-dom": "^18.2.0 || ^19.0.0",
        "styled-components": ">4.3"
    },
    "devDependencies": {
        "@babel/core": "^7.29.0",
        "@commitlint/cli": "^20.0.0",
        "@commitlint/config-conventional": "^20.0.0",
        "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
        "@eslint-react/eslint-plugin": "^3.0.0",
        "@semantic-release/changelog": "^6.0.3",
        "@semantic-release/git": "^10.0.1",
        "@storybook/addon-docs": "^10.3.3",
        "@storybook/react-vite": "^10.3.3",
        "@svgr/core": "^8.0.0",
        "@svgr/plugin-prettier": "^8.0.0",
        "@svgr/plugin-svgo": "^8.0.0",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/jest": "^30.0.0",
        "@types/jest-axe": "^3.2.1",
        "@types/jscodeshift": "^17.3.0",
        "@types/node": "^25.5.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/react-select": "^5.0.0",
        "@types/react-transition-group": "^4.2.4",
        "@types/styled-system": "^5.1.25",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.0.0",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import-x": "^4.16.2",
        "eslint-plugin-jest": "^29.15.1",
        "eslint-plugin-jsx-a11y": "^6.4.1",
        "eslint-plugin-promise": "^7.2.1",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-storybook": "^10.3.3",
        "eslint-plugin-unicorn": "^63.0.0",
        "globals": "^17.4.0",
        "husky": "^9.0.0",
        "identity-obj-proxy": "^3.0.0",
        "jest": "^30.3.0",
        "jest-axe": "^10.0.0",
        "jest-date-mock": "^1.0.8",
        "jest-environment-jsdom": "^30.3.0",
        "jest-styled-components": "^7.3.1",
        "jscodeshift": "^17.3.0",
        "minimatch": "^10.0.0",
        "prettier": "^3.0.0",
        "pretty-quick": "^4.2.2",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "react-select-event": "^5.3.0",
        "semantic-release": "^25.0.3",
        "storybook": "^10.3.3",
        "storybook-dark-mode": "^5.0.0",
        "styled-components": "^6.3.12",
        "ts-jest": "^29.4.6",
        "ts-morph": "^27.0.0",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.57.2",
        "vite": "^8.0.2",
        "yargs": "^18.0.0"
    },
    "dependencies": {
        "@datepicker-react/hooks": "^2.3.1",
        "@floating-ui/react": "^0.27.0",
        "@fontsource-variable/roboto-flex": "^5.2.8",
        "@styled-system/theme-get": "^5.1.2",
        "date-fns": "^4.1.0",
        "react-aria": "^3.47.0",
        "react-aria-components": "^1.16.0",
        "react-day-picker": "^9.14.0",
        "react-transition-group": "^4.3.0",
        "styled-system": "^5.1.5",
        "warning": "^4.0.3",
        "wave-react-windowed-select": "^1.0.0"
    }
}
